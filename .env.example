# FormForge docker-compose configuration template.
# Copy to .env and fill in real values:  cp .env.example .env

# --- PostgreSQL (external — NOT in docker-compose.yml) ---
# Point at your production DB. Options for POSTGRES_HOST:
#   - a Dokploy database service's internal name (api joins dokploy-network to reach it)
#   - host.docker.internal for a DB on the Docker host (host-gateway mapping is set)
#   - the hostname of a managed/remote Postgres
POSTGRES_HOST=your-postgres-service-name
POSTGRES_PORT=5432
POSTGRES_DB=formforge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Least-privilege, read-only role used to sandbox dataset preview queries (Story 11.3).
# You do NOT need to pre-create this on the host: the EF migration creates the
# `formforge_preview` role and the API sets its password from PREVIEW_DB_PASSWORD
# at startup (your POSTGRES_USER must have CREATEROLE — the `postgres` superuser does).
#
# SECURITY: keep PREVIEW_DB_USER = formforge_preview. Do NOT point it at `postgres`
# or any privileged account — superusers bypass the SELECT REVOKEs that hide
# password hashes, tokens and MFA secrets, so user-authored preview SQL would run
# with full read access. The password may be anything; just keep the username distinct.
PREVIEW_DB_USER=formforge_preview
PREVIEW_DB_PASSWORD=formforge_preview_dev

# --- MinIO (object storage, runs as a container) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Browser-reachable MinIO URL used to sign presigned GET URLs (images/files) and to
# allow them in the CSP. The API uploads via the internal minio:9000 host, but the
# browser must fetch from a host IT can resolve. Local dev: http://localhost:9000.
# Behind Dokploy/Traefik: https://${MINIO_DOMAIN} (must be HTTPS to avoid the
# browser blocking it as mixed content when the app is served over HTTPS).
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# --- Public domains (Dokploy/Traefik HTTPS routing) ---
# Point DNS A records for both at the VPS IP. Traefik gets Let's Encrypt certs
# automatically. Leave blank for purely-local docker compose (Traefik labels are
# then inert, but you must first run: docker network create dokploy-network).
WEB_DOMAIN=formforge.example.com
MINIO_DOMAIN=minio.example.com

# --- API ---
# 32+ char signing key. CHANGE THIS for any non-local environment.
JWT_SIGNING_KEY=dev-only-signing-key-change-this-in-production-32chars

# Session (access token) lifetime in minutes — how long a JWT is valid before
# the client must silently refresh.
ACCESS_TOKEN_TTL_MINUTES=15
# Refresh token lifetime in days — the overall sign-in window before the user
# must log in again.
REFRESH_TOKEN_TTL_DAYS=7

# --- Email (SMTP) — routed to a Mailpit instance running on the host ---
# Points at host.docker.internal so the API container reaches a standalone
# Mailpit on the host (SMTP 1025). Run one with:
#   docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
# Leave SMTP_HOST EMPTY to disable email entirely (sends are skipped). View
# captured mail in Mailpit's web UI at http://localhost:8025.
SMTP_HOST=host.docker.internal
SMTP_PORT=1025
# Mailpit needs no auth; leave User/Pass empty.
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@formforge.local
# Base URL used for login/reset links inside emails (the web frontend).
SMTP_BASE_URL=http://localhost:5173

# --- Published host ports ---
API_PORT=5000
WEB_PORT=5173
